---
// Logo Zone Component - Displays the three brand logos above navigation
import { Image } from 'astro:assets';
import mocesLogo from '../assets/moces.svg';
import zonaLogo from '../assets/zonadesconforto.png';
import comfyLogo from '../assets/comfy.png';
---

<section class="relative w-full py-4 flex justify-center items-center bg-transparent">
  <div class="flex flex-row items-center gap-[41px] px-5 lg:gap-20">
    <!-- Hamburger menu (visible on mobile/tablet) -->
    <button id="menu-toggle" class="lg:hidden flex flex-col justify-center items-center w-12 h-12 rounded-[80px] bg-[#B496C8] shadow-[0_4px_20px_rgba(180,150,200,0.3)] flex-shrink-0" aria-label="Abrir menu de navegação">
      <span class="w-6 h-[2px] bg-white rounded-sm"></span>
      <span class="w-6 h-[2px] bg-white rounded-sm my-1"></span>
      <span class="w-6 h-[2px] bg-white rounded-sm"></span>
    </button>

    <!-- Logos container - horizontal row (balanced visual weight) -->
    <div class="flex flex-row items-center gap-4 sm:gap-6">
      <!-- Moces Logo (smaller - has hands icon making it visually taller) -->
      <div class="flex items-center justify-center flex-shrink-0 h-[32px] sm:h-[42px] w-auto">
        <Image
          src={mocesLogo}
          alt="Moces - Organização sem fins lucrativos"
          width={60}
          height={75}
          loading="eager"
          decoding="async"
          class="h-full w-auto object-contain"
        />
      </div>

      <!-- Zona de(s) Conforto Logo -->
      <div class="flex items-center justify-center flex-shrink-0 h-[45px] sm:h-[55px] w-auto">
        <Image
          src={zonaLogo}
          alt="Zona de(s) Conforto"
          width={80}
          height={80}
          loading="eager"
          decoding="async"
          class="h-full w-auto object-contain"
        />
      </div>

      <!-- Comfy Logo (larger - more compact design) -->
      <div class="flex items-center justify-center flex-shrink-0 h-[60px] sm:h-[70px] w-auto">
        <Image
          src={comfyLogo}
          alt="Comfy App"
          width={80}
          height={95}
          loading="eager"
          decoding="async"
          class="h-full w-auto object-contain"
        />
      </div>
    </div>
  </div>
  <script is:inline>
    const btn = document.getElementById('menu-toggle');
    if (btn) {
      btn.addEventListener('click', () => {
        window.dispatchEvent(new Event('toggle-menu'));
      });
    }
  </script>
</section>
